# ── Servidor ──────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────
# Crie gratuitamente em https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cortex?retryWrites=true&w=majority

# ── JWT ───────────────────────────────
# Gere uma string aleatória segura (ex: openssl rand -base64 64)
JWT_SECRET=sua_chave_secreta_super_longa_aqui
JWT_EXPIRES_IN=7d

# ── Cloudflare R2 (ou AWS S3) ─────────
# Cloudflare R2: https://dash.cloudflare.com → R2 → Manage API tokens
STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=<access_key_id>
STORAGE_SECRET_KEY=<secret_access_key>
STORAGE_BUCKET=cortex-files

# URL pública dos arquivos (CDN ou R2 public bucket)
STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── CORS ──────────────────────────────
CLIENT_URL=http://localhost:5173
